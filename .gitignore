# Git ignore patterns

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor directories and files
.idea/
.vscode/
*.swp
*.swo
*~

# Dependencies
node_modules/

# Build outputs
dist/
build/
*.log

# Test coverage
coverage/

# Temporary files
*.tmp
*.temp
.cache/

# Development files
*.bak
*.backup

# Documentation builds
docs/_build/

# Package files
*.zip
*.tar.gz
*.rar
